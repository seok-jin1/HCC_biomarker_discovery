# =============================================================================
# .gitignore — HCC scRNA-seq project
# Exclude large data files, model checkpoints, and caches.
# =============================================================================

# ---------------------------------------------------------------------------
# Large biological data formats
# ---------------------------------------------------------------------------
*.h5ad
*.h5
*.rds
*.RData
*.gct
*.gct.gz
*.mtx
*.mtx.gz
*.tar
*.CEL

# ---------------------------------------------------------------------------
# Raw / processed data directories
# ---------------------------------------------------------------------------
data/
/mnt/

# ---------------------------------------------------------------------------
# Python caches and build artefacts
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# ML experiment tracking
# ---------------------------------------------------------------------------
wandb/
lightning_logs/
mlruns/
runs/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
.conda/

# ---------------------------------------------------------------------------
# OS / editor artefacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ---------------------------------------------------------------------------
# Secrets / credentials
# ---------------------------------------------------------------------------
.env
*.pem
*.key
